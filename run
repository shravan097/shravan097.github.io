#!/usr/bin/env bash
set -e
cd "$(dirname "$0")"

if [ ! -f bin/activate-hermit ]; then
  echo "First-time Hermit setup: run the following, then run this script again:"
  echo "  hermit init"
  echo "  . bin/activate-hermit"
  echo "  hermit install node"
  echo "  npm install"
  echo ""
  echo "See bin/README.hermit.md for full instructions."
  exit 1
fi

. bin/activate-hermit

if [ ! -d node_modules ]; then
  echo "Installing npm dependencies..."
  npm install
fi

npm run develop
